{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["../src/index.ts"],
  "includeVersion": true,
  "excludeExternals": true,
  "excludeInternal": true,
  "jsDocCompatibility": false,
  "excludeTags": ["@knipignore"],
  "sort": ["alphabetical", "kind"],
  "kindSortOrder": [
    "Project",
    "Module",
    "Namespace",
    "TypeAlias",
    "Interface",
    "Class",
    "Reference",
    "Enum",
    "EnumMember",
    "Constructor",
    "Property",
    "Variable",
    "Function",
    "Accessor",
    "Method",
    "Parameter",
    "TypeParameter",
    "TypeLiteral",
    "CallSignature",
    "ConstructorSignature",
    "IndexSignature",
    "GetSignature",
    "SetSignature"
  ]
}
